{
  "name": "winnow",
  "version": "1.0.0",
  "private": true,
  "description": "Proxy rotator with persistent health, multi-target scoring, dashboard and JS validator",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "validator": "node dist/validator/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test src/__tests__/*.test.ts",
    "pretest": "npm run clean && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "better-sqlite3@12.11.1": true
  }
}
